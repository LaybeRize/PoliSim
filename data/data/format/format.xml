<?xml version="1.0" encoding="UTF-8" ?>
<root>
    <table name="account">
        <id name="ID" primaryKey="true" autoIncrement="true">int64</id>
        <display_name name="DisplayName">string</display_name>
        <flair name="AccountFlair">string</flair>
        <username name="Username">string</username>
        <password name="Password">string</password>
        <suspended name="Suspended">bool</suspended>
        <login_tries name="LoginTries">bool</login_tries>
        <next_login_time name="NextLoginTime">time.Time</next_login_time>
        <role name="Role">int8</role>
        <linked name="Linked">int64</linked>
        <has_letters name="HasLetters">bool</has_letters>
        <parent name="Parent">int64</parent>
    </table>
    <table name="document">
        <uuid name="DocUUID" primaryKey="true">string</uuid>
        <written name="DocDate">time.Time</written>
        <organisation name="DocOrganisation">string</organisation>
        <type name="DocType">string</type>
        <author name="DocAuthor">string</author>
        <flair name="DocFlair">string</flair>
        <title name="DocTitle">string</title>
        <subtitle name="DocSubtitle">string</subtitle>
        <html_content name="DocHTML">string</html_content>
        <private name="DocPrivate">bool</private>
        <blocked name="DocBlocked">bool</blocked>
        <current_tag name="CurrentPostTag">string</current_tag>
        <any_p_allowed name="AnyPosterAllowed">bool</any_p_allowed>
        <org_p_allowed name="OrganisationPosterAllowed">bool</org_p_allowed>
        <info name="DocumentInfo" dbType="JSONB">DocumentInfo</info>
    </table>
    <jointable name="doc_allowed">
        <column alias="ID" table="account"/>
        <column alias="DocUUID" table="document"/>
    </jointable>
    <view>

    </view>
    <querie name="FindFullAccountByName" parameter="name string">
        <statement>SELECT * FROM account WHERE DisplayName=:name</statement>
        <columns table="account">*</columns>
    </querie>
</root>